#include <Arduino.h>
#include "FastAccelStepper.h"

// --- 使用 XIAO ESP32S3 的 D0, D1, D2 引脚对应的 GPIO ---
#define EN_PIN   1  
#define STEP_PIN 2  
#define DIR_PIN  3  

FastAccelStepperEngine engine = FastAccelStepperEngine();
FastAccelStepper *stepper = NULL;

void setup() {
  Serial.begin(115200);
  Serial.println("PIO 环境下单轴极简测试启动！");

  // 初始化步进引擎
  engine.init();

  // 绑定引脚并初始化电机对象
  stepper = engine.stepperConnectToPin(STEP_PIN);
  if (stepper) {
    stepper->setDirectionPin(DIR_PIN);
    stepper->setEnablePin(EN_PIN);
    stepper->setAutoEnable(true); 

    stepper->setSpeedInHz(4000);       // 最大速度
    stepper->setAcceleration(15000);   // 加速度
  } else {
    Serial.println("电机初始化失败，请检查引脚！");
    while(true);
  }
}

void loop() {
  if (!stepper->isRunning()) {
    Serial.println("正向平滑移动 3000 步...");
    stepper->moveTo(3000); 
    
    while(stepper->isRunning()) {
      delay(10);
    }
    
    Serial.println("到达目标，休息 1 秒...");
    delay(1000);

    Serial.println("反向平滑退回起点 (0)...");
    stepper->moveTo(0);
    
    while(stepper->isRunning()) {
      delay(10);
    }

    Serial.println("复位成功，休息 1 秒后继续...");
    delay(1000);
  }
