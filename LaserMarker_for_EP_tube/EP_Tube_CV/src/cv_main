// 启动 Web 服务器
void startCameraServer() {
  httpd_config_t config = HTTPD_DEFAULT_CONFIG();
  config.server_port = 80;

  httpd_uri_t index_uri = {
    .uri       = "/",
    .method    = HTTP_GET,
    .handler   = stream_handler,
    .user_ctx  = NULL
  };

  Serial.printf("Starting web server on port: '%d'\n", config.server_port);
  if (httpd_start(&stream_httpd, &config) == ESP_OK) {
    httpd_register_uri_handler(stream_httpd, &index_uri);
  }
}

// =================== 4. Setup & Loop ===================
void setup() {
  // 1. 防止欠压重启
  WRITE_PERI_REG(RTC_CNTL_BROWN_OUT_REG, 0); 

  // 2. 初始化板载黄色 LED (XIAO S3 的 LED_BUILTIN 通常是 Pin 21)
  pinMode(LED_BUILTIN, OUTPUT);
  
  // === 视觉信号：闪烁 3 次 ===
  // 意思：告诉我不光通电了，代码也开始跑了！
  for(int i=0; i<3; i++) {
    digitalWrite(LED_BUILTIN, LOW);  // XIAO 的 LED 是低电平亮
    delay(100);
    digitalWrite(LED_BUILTIN, HIGH); // 灭
    delay(100);
  }

  // 3. 启动串口
  Serial.begin(115200);
  
  // === 缓冲时间：给你 3 秒钟打开串口监视器 ===
  // 烧录完按 Reset 后，这 3 秒内你可以从容地打开 Monitor
  delay(3000); 

  Serial.println("\n\n=== 系统启动 ===");
  Serial.println("正在尝试连接 WiFi...");

  // 4. 摄像头配置
  WRITE_PERI_REG(RTC_CNTL_BROWN_OUT_REG, 0); // 禁用欠压检测，防止重启

  Serial.begin(115200);
  Serial.setDebugOutput(false);
  
  camera_config_t config;
  config.ledc_channel = LEDC_CHANNEL_0;
  config.ledc_timer = LEDC_TIMER_0;
  config.pin_d0 = Y2_GPIO_NUM;
  config.pin_d1 = Y3_GPIO_NUM;
  config.pin_d2 = Y4_GPIO_NUM;
  config.pin_d3 = Y5_GPIO_NUM;
  config.pin_d4 = Y6_GPIO_NUM;
  config.pin_d5 = Y7_GPIO_NUM;
  config.pin_d6 = Y8_GPIO_NUM;
  config.pin_d7 = Y9_GPIO_NUM;
  config.pin_xclk = XCLK_GPIO_NUM;
  config.pin_pclk = PCLK_GPIO_NUM;
  config.pin_vsync = VSYNC_GPIO_NUM;
  config.pin_href = HREF_GPIO_NUM;
  config.pin_sccb_sda = SIOD_GPIO_NUM;
  config.pin_sccb_scl = SIOC_GPIO_NUM;
  config.pin_pwdn = PWDN_GPIO_NUM;
  config.pin_reset = RESET_GPIO_NUM;
  config.xclk_freq_hz = 20000000;
  
  // 重要：数据采集通常用正方形图片，适合神经网络输入
  config.frame_size = FRAMESIZE_240X240; 
  config.pixel_format = PIXFORMAT_JPEG; 
  config.grab_mode = CAMERA_GRAB_WHEN_EMPTY;
  config.fb_location = CAMERA_FB_IN_PSRAM;
  config.jpeg_quality = 10; // 0-63, 数字越小质量越高
